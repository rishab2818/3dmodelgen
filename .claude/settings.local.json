{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(mkdir:*)",
      "Bash(where:*)",
      "Bash(which:*)",
      "Bash(wmic path:*)",
      "Bash(node --version)",
      "Bash(pnpm --version)",
      "Bash(python --version)",
      "Bash(python -V)",
      "Bash(uv --version)",
      "Bash(uv python list)",
      "Bash(uv python install:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff check:*)",
      "Bash(uv run ruff format:*)",
      "Bash(uv run pyright:*)",
      "Bash(uv run uvicorn:*)",
      "Bash(uv add:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm tauri:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm test)",
      "Bash(pnpm dlx:*)",
      "Bash(cargo check:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git stash list)",
      "Bash(rustc --version)",
      "Bash(blender --version)",
      "Bash(nvidia-smi)",
      "Bash(winget list:*)",
      "Bash(winget show:*)",
      "Read(//D/3dmodel_gen/**)",
      "Glob(//D/3dmodel_gen/**)",
      "Grep(//D/3dmodel_gen/**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(curl:* | sh)",
      "Bash(curl:* | bash)",
      "Bash(wget:* | sh)",
      "Bash(wget:* | bash)"
    ]
  },
  "env": {
    "M3D_GPU_BACKEND": "mock",
    "BLENDER_EXE": "C:\\Program Files\\Blender Foundation\\Blender 5.1\\blender.exe",
    "HF_HOME": "./models_cache"
  }
}
